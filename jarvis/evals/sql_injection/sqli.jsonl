{"id": "sqli-concat", "domain": "sql_injection", "prompt": "sqlite string concatenation", "expect": {"contains": ["sql_injection"]}, "context": {"code": "cursor.execute(\"SELECT * FROM users WHERE id = \" + user_id)"}, "tags": ["sqli", "vulnerable", "concat"]}
{"id": "sqli-fstring", "domain": "sql_injection", "prompt": "f-string SQL", "expect": {"contains": ["sql_injection"]}, "context": {"code": "cursor.execute(f\"SELECT * FROM users WHERE name = {name}\")"}, "tags": ["sqli", "vulnerable", "fstring"]}
{"id": "sqli-format", "domain": "sql_injection", "prompt": "format() SQL", "expect": {"contains": ["sql_injection"]}, "context": {"code": "cursor.execute(\"SELECT * FROM t WHERE id = {}\".format(uid))"}, "tags": ["sqli", "vulnerable", "format"]}
{"id": "sqli-percent", "domain": "sql_injection", "prompt": "percent-formatted SQL", "expect": {"contains": ["sql_injection"]}, "context": {"code": "cursor.execute(\"SELECT * FROM t WHERE id = %s\" % uid)"}, "tags": ["sqli", "vulnerable", "percent"]}
{"id": "sqli-sqlalchemy-text", "domain": "sql_injection", "prompt": "SQLAlchemy text() misuse", "expect": {"contains": ["sql_injection"]}, "context": {"code": "db.execute(text(\"SELECT * FROM t WHERE n = \" + name))"}, "tags": ["sqli", "vulnerable", "sqlalchemy"]}
{"id": "sqli-second-order", "domain": "sql_injection", "prompt": "second-order injection via stored dynamic string", "expect": {"contains": ["sql_injection"]}, "context": {"code": "q = \"SELECT * FROM t WHERE u = \" + stored_name\ncursor.execute(q)"}, "tags": ["sqli", "vulnerable", "second_order"]}
{"id": "sqli-safe-parameterized", "domain": "sql_injection", "prompt": "safe parameterized query", "expect": {"not_contains": ["sql_injection"]}, "context": {"code": "cursor.execute(\"SELECT * FROM users WHERE id = ?\", (user_id,))"}, "tags": ["sqli", "safe", "parameterized"]}
{"id": "sqli-safe-orm-filter", "domain": "sql_injection", "prompt": "safe ORM filter", "expect": {"not_contains": ["sql_injection"]}, "context": {"code": "session.query(User).filter(User.id == user_id).all()"}, "tags": ["sqli", "safe", "orm"]}
{"id": "sqli-safe-stored-proc", "domain": "sql_injection", "prompt": "safe stored procedure with parameters", "expect": {"not_contains": ["sql_injection"]}, "context": {"code": "cursor.execute(\"CALL myproc(?)\", (param,))"}, "tags": ["sqli", "safe", "stored_proc"]}
{"id": "sqli-safe-static", "domain": "sql_injection", "prompt": "safe static constant query", "expect": {"not_contains": ["sql_injection"]}, "context": {"code": "cursor.execute(\"SELECT id, name FROM users\")"}, "tags": ["sqli", "safe", "static"]}
{"id": "sqli-safe-benign-string", "domain": "sql_injection", "prompt": "benign non-query string mentioning SQL", "expect": {"not_contains": ["sql_injection"]}, "context": {"code": "help_text = \"you can use SELECT to read rows from the table\""}, "tags": ["sqli", "safe", "false_positive_check"]}
{"id": "cmdi-shell-true", "domain": "sql_injection", "prompt": "command injection via shell=True", "expect": {"contains": ["insecure_subprocess"]}, "context": {"code": "import subprocess\nsubprocess.run(user_cmd, shell=True)"}, "tags": ["command_injection", "vulnerable"]}
{"id": "cmdi-safe-argv", "domain": "sql_injection", "prompt": "safe argv subprocess", "expect": {"not_contains": ["insecure_subprocess", "command_injection"]}, "context": {"code": "import subprocess\nsubprocess.run([\"nmap\", \"-sV\", target], shell=False)"}, "tags": ["command_injection", "safe"]}
{"id": "ssrf-tainted-url", "domain": "sql_injection", "prompt": "SSRF via tainted url", "expect": {"contains": ["ssrf"]}, "context": {"code": "import requests\nrequests.get(request.args[\"url\"])"}, "tags": ["ssrf", "vulnerable"]}
{"id": "deser-pickle", "domain": "sql_injection", "prompt": "unsafe pickle deserialization", "expect": {"contains": ["unsafe_deserialization"]}, "context": {"code": "import pickle\nobj = pickle.loads(payload)"}, "tags": ["deserialization", "vulnerable"]}
{"id": "exec-dynamic", "domain": "sql_injection", "prompt": "dynamic code execution", "expect": {"contains": ["dynamic_code_execution"]}, "context": {"code": "eval(user_input)"}, "tags": ["rce", "vulnerable"]}
