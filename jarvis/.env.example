# ── Anthropic ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ElevenLabs (opcional — si no la pones usa pyttsx3 offline) ─
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Personalidad del asistente ─────────────────────────────────
ASSISTANT_NAME=Alicia
USER_NAME=Alejandro
CITY=Panama

# ── STT ────────────────────────────────────────────────────────
WHISPER_MODEL=small          # tiny | base | small | medium
WHISPER_LANGUAGE=es          # es | en | auto

# ── Audio ──────────────────────────────────────────────────────
RECORD_SECONDS=5             # segundos de grabación por turno
SAMPLE_RATE=16000

# ── Forensics ──────────────────────────────────────────────────
# Absolute path to the target VM's .vmx file.
# When a canary honeypot receives a high-confidence banner (>16 bytes),
# JARVIS will snapshot → suspend the VM and run Volatility 3 on the dump.
# Leave empty to disable the automatic forensic capture pipeline.
VMX_TARGET_PATH=             # e.g. C:\VMs\Win10-Target\Win10-Target.vmx
