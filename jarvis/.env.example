# ── Ollama host (V66.1 — normalized to scheme://host:port) ──────
# A bare host (127.0.0.1) is auto-normalized to http://127.0.0.1:11434 by the
# runtime AND the diagnostics, but prefer the full URL form here.
OLLAMA_HOST=http://127.0.0.1:11434

# ── LLM (Ollama local — primary) ────────────────────────────────
LLM_MODEL=qwen3:8b            # local Ollama model tag (matches FAST role)
LLM_MAX_TOKENS=2048            # 256–8192

# ── Claude / Anthropic (optional deep-reasoning backend) ────────
ANTHROPIC_API_KEY=             # sk-ant-... — leave blank to stay local-only

# ── OpenRouter (optional cloud fallback, OpenAI-compatible) ─────
OPENROUTER_API_KEY=            # sk-or-... — enables cloud model fallback
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# ── Model overrides (legacy dual-model hint — leave blank = auto) ─
MODEL_FAST_OVERRIDE=           # leave blank = auto (JARVIS_MODEL_FAST wins)
MODEL_DEEP_OVERRIDE=           # leave blank = auto (JARVIS_MODEL_DEEP wins)

# ── Role-based router — UNIFIED model resolution (V66.1) ─────────
# Single source of truth. Precedence (highest first):
#   1) these explicit JARVIS_MODEL_* overrides  (ALWAYS win)
#   2) central role config (the defaults shown below)
#   3) hardware-aware recommendation             (advisory only)
#   4) installed-compatible fallback
#   5) safe fallback
# Every consumer (LLM turns, specialist runtime, planner, correlator, ARES,
# purple coordinator, cognitive engine, vision) resolves through this ladder,
# so what you set here is what actually runs. Leave blank to use the defaults.
JARVIS_MODEL_FAST=qwen3:8b               # chat / low-latency  (default qwen3:8b)
JARVIS_MODEL_CODER=qwen2.5-coder:latest  # code (default qwen2.5-coder:latest)
JARVIS_MODEL_DEEP=qwen3:14b              # architecture/DFIR   (default qwen3:14b)
JARVIS_MODEL_VISION=gemma3:4b            # screenshots/OCR     (default gemma3:4b)
JARVIS_MODEL_EMBEDDING=nomic-embed-text:latest  # RAG (default nomic-embed-text:latest)
JARVIS_MODEL_VERIFIER=qwen3:8b           # review/verify       (default qwen3:8b)
JARVIS_CLOUD_ENABLED=false     # true to allow cloud escalation
JARVIS_CLOUD_PROVIDER=         # e.g. openrouter
JARVIS_CLOUD_MODEL=            # e.g. anthropic/claude-sonnet-4-6

# ── Ollama runtime posture (Ryzen 5 7430U / 64 GB — CPU inference) ─
# Set these in Ollama's environment (not read by JARVIS). Conservative on a
# 15W CPU-bound host: one model resident, no parallel decode.
#   OLLAMA_NUM_PARALLEL=1
#   OLLAMA_MAX_LOADED_MODELS=1

# ── Trusted lab mode (DANGEROUS — isolated authorized lab only) ──
# true relaxes destructive-pattern guardrails and allows HTTP to internal
# ranges. Read ONLY from here/env, never from model/tool input. Keep OFF on
# any machine with reachable production networks.
JARVIS_TRUSTED_LAB=false

# ── ElevenLabs (optional — falls back to pyttsx3 offline) ──────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Persona ─────────────────────────────────────────────────────
ASSISTANT_NAME=Jarvis
USER_NAME=Alejandro
CITY=Panama

# ── STT ─────────────────────────────────────────────────────────
WHISPER_MODEL=small            # tiny | base | small | medium | large
WHISPER_LANGUAGE=es            # ISO 639-1 code or "auto"

# ── Audio ────────────────────────────────────────────────────────
RECORD_SECONDS=5               # 1–60
SAMPLE_RATE=16000              # 8000 | 16000 | 22050 | 44100 | 48000

# ── VMware / Forensics ───────────────────────────────────────────
# Absolute path to the target VM .vmx — used by canary trigger for live forensic capture.
# Leave empty to disable automatic forensic pipeline.
VMX_TARGET_PATH=               # e.g. C:\VMs\Win10-Target\Win10-Target.vmx

# Path to vmrun.exe (used by forensic_volatility, resource_sentinel, deception_orchestrator).
VMRUN_PATH=C:\Program Files (x86)\VMware\VMware Workstation\vmrun.exe

# Comma-separated list of secondary .vmx files to suspend under resource pressure.
SECONDARY_VMS=                 # e.g. C:\VMs\Kali\Kali.vmx,C:\VMs\Server\Server.vmx

# ── Offensive RPC (Metasploit msfrpcd) ──────────────────────────
MSF_HOST=192.168.1.100
MSF_PORT=55553
MSF_PASSWORD=msf

# ── Zeek DPI ─────────────────────────────────────────────────────
ZEEK_LOG_DIR=/mnt/zeek/logs/current
DNS_QUERY_LEN_THRESHOLD=52     # bytes — flag queries longer than this
DNS_QUERY_RATE_THRESHOLD=100   # queries/min per source IP

# ── Environmental Intel ──────────────────────────────────────────
DEFAULT_LAT=9.3592             # decimal degrees — fallback if GPS unavailable
DEFAULT_LON=-79.9014
ENV_POLL_INTERVAL=900          # seconds (15-minute floor respects rate limits)

# ── Threat Feed Sync ─────────────────────────────────────────────
THREAT_FEED_SYNC_INTERVAL=86400  # seconds (default: 24 h)

# ── Resource Sentinel ────────────────────────────────────────────
RAM_FREE_FLOOR=8.0             # % free RAM below which VMs are suspended
CPU_TEMP_CEIL=85.0             # °C — thermal ceiling
SUSPEND_COOLDOWN=120           # seconds — hysteresis to prevent flapping

# ── Mitigation (SOAR) ────────────────────────────────────────────
ENTROPY_THRESHOLD=5.0          # Shannon AND-gate for IP isolation

# ── Agentic Loop ─────────────────────────────────────────────────
AGENTIC_MAX_CYCLES=8
AGENTIC_LOOP_TIMEOUT=120       # seconds
